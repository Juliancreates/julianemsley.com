---
interface Artwork {
  id: string;
  data: {
    title: string;
    year: number;
    medium?: string;
    dimensions?: string;
    image: string;
    order: number;
  };
}

interface Props {
  works: Artwork[];
}

const { works } = Astro.props;
const sorted = [...works].sort((a, b) => a.data.order - b.data.order);
---

<div class="gallery">
  {sorted.map((work, i) => (
    <figure
      class="gallery-item"
      data-index={i}
      style={`animation-delay: ${i * 60}ms`}
    >
      <button
        class="gallery-trigger"
        aria-label={`View ${work.data.title}`}
        data-title={work.data.title}
        data-year={work.data.year}
        data-medium={work.data.medium || ''}
        data-dimensions={work.data.dimensions || ''}
        data-src={work.data.image}
      >
        <img
          src={work.data.image}
          alt={`${work.data.title}, ${work.data.year}`}
          loading={i < 6 ? 'eager' : 'lazy'}
          decoding="async"
          class="gallery-img"
        />
        <figcaption class="gallery-caption">
          <span class="caption-title">{work.data.title}</span>
          <span class="caption-year">{work.data.year}</span>
        </figcaption>
      </button>
    </figure>
  ))}
</div>

<!-- Lightbox -->
<dialog class="lightbox" id="lightbox" aria-label="Artwork detail view">
  <div class="lightbox-inner">
    <img class="lightbox-img" src="" alt="" />
    <div class="lightbox-info">
      <h2 class="lightbox-title"></h2>
      <p class="lightbox-meta"></p>
    </div>
    <button class="lightbox-close" aria-label="Close">&times;</button>
    <button class="lightbox-prev" aria-label="Previous work">&larr;</button>
    <button class="lightbox-next" aria-label="Next work">&rarr;</button>
  </div>
</dialog>

<script>
  const gallery = document.querySelector('.gallery');
  const dialog = document.getElementById('lightbox') as HTMLDialogElement;
  const lbImg = dialog?.querySelector('.lightbox-img') as HTMLImageElement;
  const lbTitle = dialog?.querySelector('.lightbox-title') as HTMLElement;
  const lbMeta = dialog?.querySelector('.lightbox-meta') as HTMLElement;
  const lbClose = dialog?.querySelector('.lightbox-close') as HTMLButtonElement;
  const lbPrev = dialog?.querySelector('.lightbox-prev') as HTMLButtonElement;
  const lbNext = dialog?.querySelector('.lightbox-next') as HTMLButtonElement;

  const triggers = Array.from(document.querySelectorAll('.gallery-trigger')) as HTMLButtonElement[];
  let currentIndex = 0;

  function showWork(index: number) {
    const btn = triggers[index];
    if (!btn) return;
    currentIndex = index;

    const { src, title, year, medium, dimensions } = btn.dataset;
    lbImg.src = src || '';
    lbImg.alt = `${title}, ${year}`;
    lbTitle.textContent = `${title} — ${year}`;

    const metaParts = [medium, dimensions].filter(Boolean);
    lbMeta.textContent = metaParts.join(' · ');

    lbPrev.style.visibility = index > 0 ? 'visible' : 'hidden';
    lbNext.style.visibility = index < triggers.length - 1 ? 'visible' : 'hidden';
  }

  // Open
  gallery?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.gallery-trigger') as HTMLButtonElement;
    if (!btn) return;
    const index = triggers.indexOf(btn);
    showWork(index);
    dialog?.showModal();
  });

  // Close
  lbClose?.addEventListener('click', () => dialog?.close());
  dialog?.addEventListener('click', (e) => {
    if (e.target === dialog) dialog.close();
  });

  // Nav
  lbPrev?.addEventListener('click', () => showWork(currentIndex - 1));
  lbNext?.addEventListener('click', () => showWork(currentIndex + 1));

  // Keyboard
  dialog?.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowLeft' && currentIndex > 0) showWork(currentIndex - 1);
    if (e.key === 'ArrowRight' && currentIndex < triggers.length - 1) showWork(currentIndex + 1);
  });
</script>

<style>
  /* ---- Gallery Grid ---- */
  .gallery {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(var(--grid-min), 1fr));
    gap: var(--grid-gap);
    padding-top: 3.5rem; /* clear fixed header */
  }

  .gallery-item {
    position: relative;
    overflow: hidden;
    animation: fadeUp var(--t-slow) var(--ease-out) both;
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .gallery-trigger {
    display: block;
    width: 100%;
    padding: 0;
    position: relative;
    overflow: hidden;
    aspect-ratio: 4 / 3;
  }

  .gallery-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--t-slow) var(--ease-out);
  }

  .gallery-trigger:hover .gallery-img,
  .gallery-trigger:focus-visible .gallery-img {
    transform: scale(1.03);
  }

  /* Caption overlay — visible on hover */
  .gallery-caption {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    padding: calc(var(--s-unit) * 3);
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.55) 0%,
      transparent 50%
    );
    opacity: 0;
    transition: opacity var(--t-base) var(--ease-out);
  }

  .gallery-trigger:hover .gallery-caption,
  .gallery-trigger:focus-visible .gallery-caption {
    opacity: 1;
  }

  .caption-title {
    font-size: var(--f-size-sm);
    font-weight: 400;
    letter-spacing: 0.02em;
    color: var(--c-text);
  }

  .caption-year {
    font-size: var(--f-size-xs);
    color: var(--c-text-dim);
    margin-top: 2px;
  }

  /* ---- Lightbox (native <dialog>) ---- */
  .lightbox {
    max-width: 100vw;
    max-height: 100dvh;
    width: 100%;
    height: 100%;
    border: none;
    padding: 0;
    background: var(--c-overlay);
    color: var(--c-text);
  }

  .lightbox::backdrop {
    background: transparent; /* we handle our own bg */
  }

  .lightbox[open] {
    display: flex;
    align-items: center;
    justify-content: center;
    animation: lbFadeIn var(--t-base) var(--ease-out);
  }

  @keyframes lbFadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  .lightbox-inner {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    padding: var(--s-page);
  }

  .lightbox-img {
    max-width: 90vw;
    max-height: 75dvh;
    object-fit: contain;
    border-radius: 1px;
  }

  .lightbox-info {
    margin-top: calc(var(--s-unit) * 3);
    text-align: center;
  }

  .lightbox-title {
    font-size: var(--f-size-sm);
    font-weight: 400;
    letter-spacing: 0.03em;
  }

  .lightbox-meta {
    font-size: var(--f-size-xs);
    color: var(--c-text-dim);
    margin-top: 4px;
  }

  .lightbox-close {
    position: absolute;
    top: var(--s-gutter);
    right: var(--s-gutter);
    font-size: 1.5rem;
    line-height: 1;
    color: var(--c-text-dim);
    transition: color var(--t-fast);
    z-index: 10;
  }
  .lightbox-close:hover { color: var(--c-text); }

  .lightbox-prev,
  .lightbox-next {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    font-size: 1.25rem;
    color: var(--c-text-dim);
    transition: color var(--t-fast);
    padding: var(--s-unit);
    z-index: 10;
  }
  .lightbox-prev { left: var(--s-gutter); }
  .lightbox-next { right: var(--s-gutter); }
  .lightbox-prev:hover,
  .lightbox-next:hover { color: var(--c-text); }

  /* ---- Responsive ---- */
  @media (max-width: 640px) {
    .gallery {
      grid-template-columns: 1fr;
      gap: 2px;
    }

    .lightbox-img {
      max-width: 95vw;
      max-height: 65dvh;
    }
  }

  @media (min-width: 1200px) {
    .gallery {
      --grid-min: 320px;
    }
  }
</style>
