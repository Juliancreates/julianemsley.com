---
interface Image {
  src: string;
  alt: string;
}

interface Props {
  images: Image[];
}

const { images } = Astro.props;
---

<div class="gallery">
  {images.map((image) => (
    <figure>
      <img src={image.src} alt={image.alt} loading="lazy" />
    </figure>
  ))}
</div>

<style>
  .gallery {
    display: flex;
    align-items: center;
    gap: 1rem;
    overflow-x: auto;
    overflow-y: hidden;
    height: 100svh;
    padding: 0.75rem 1rem;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
  }

  .gallery::-webkit-scrollbar {
    display: none;
  }

  figure {
    flex-shrink: 0;
    height: 100%;
    display: flex;
    align-items: center;
  }

  figure img {
    height: 100%;
    max-height: 700px;
    width: auto;
    display: block;
    object-fit: contain;
  }

  @media (min-width: 768px) {
    .gallery {
      height: 100vh;
      padding: 0.75rem 1rem 0.75rem 300px;
      gap: 1rem;
    }
  }
</style>
