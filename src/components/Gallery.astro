---
interface Image {
  src: string;
  alt: string;
  title?: string;
  medium?: string;
  year?: string;
  dimensions?: string;
}

interface Props {
  images: Image[];
}

const { images } = Astro.props;
---

<div class="gallery">
  {images.map((image) => (
    <figure>
      <img
        src={image.src}
        alt={image.alt}
        loading="lazy"
        class="gallery-img"
        data-title={image.title ?? 'Untitled'}
        data-medium={image.medium ?? 'Oil on canvas'}
        data-year={image.year ?? ''}
        data-dimensions={image.dimensions ?? ''}
      />
    </figure>
  ))}
</div>

<!-- Lightbox -->
<div class="lightbox" id="lightbox" aria-modal="true" role="dialog" aria-hidden="true">
  <button class="lightbox-close" id="lightbox-close" aria-label="Close">
    <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
      <line x1="1" y1="1" x2="17" y2="17" stroke="#fff" stroke-width="1.5" stroke-linecap="round"/>
      <line x1="17" y1="1" x2="1" y2="17" stroke="#fff" stroke-width="1.5" stroke-linecap="round"/>
    </svg>
  </button>
  <div class="lightbox-backdrop" id="lightbox-backdrop"></div>
  <div class="lightbox-inner">
    <div class="lightbox-image-area">
      <img class="lightbox-img" id="lightbox-img" src="" alt="" />
    </div>
    <div class="lightbox-card">
      <p class="lightbox-title" id="lightbox-title"></p>
      <p class="lightbox-meta" id="lightbox-meta"></p>
      <p class="lightbox-dims" id="lightbox-dims"></p>
    </div>
  </div>
</div>

<style>
  .gallery {
    display: flex;
    align-items: center;
    gap: 1rem;
    overflow-x: auto;
    overflow-y: hidden;
    height: 100svh;
    padding: 0.75rem 1rem;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
  }

  .gallery::-webkit-scrollbar {
    display: none;
  }

  figure {
    flex-shrink: 0;
    height: 100%;
    display: flex;
    align-items: center;
  }

  figure img {
    height: 100%;
    max-height: 700px;
    width: auto;
    display: block;
    object-fit: contain;
  }

  .gallery-img { cursor: pointer; }

  @media (max-width: 767px) {
    .gallery {
      height: 100%;
      min-height: 0;
      padding: 0.75rem 1rem;
    }
  }

  @media (min-width: 768px) {
    .gallery {
      height: 100vh;
      padding: 0.75rem 1rem 0.75rem 300px;
      gap: 1rem;
    }
  }

  /* ── Lightbox ── */
  .lightbox {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 200;
    flex-direction: column;
  }
  .lightbox.open { display: flex; }

  .lightbox-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.85);
  }

  .lightbox-close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    z-index: 210;
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px;
    line-height: 0;
  }

  .lightbox-inner {
    position: relative;
    z-index: 205;
    display: flex;
    flex-direction: column;
    width: 100%;
    height: 100%;
  }

  .lightbox-image-area {
    flex: 0 0 65%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 3rem 1.5rem 1rem;
    opacity: 0;
    transition: opacity 0.25s ease;
  }
  .lightbox.open .lightbox-image-area { opacity: 1; }

  .lightbox-img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    display: block;
  }

  .lightbox-card {
    flex: 0 0 35%;
    background: #fff;
    padding: 1.5rem 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.25s ease 0.08s, transform 0.25s ease 0.08s;
  }
  .lightbox.open .lightbox-card {
    opacity: 1;
    transform: translateY(0);
  }

  .lightbox-title {
    font-family: 'Lato', sans-serif;
    font-size: 15px;
    color: #222;
  }
  .lightbox-meta {
    font-family: 'Lato', sans-serif;
    font-size: 13px;
    color: #999;
  }
  .lightbox-dims {
    font-family: 'Lato', sans-serif;
    font-size: 13px;
    color: #bbb;
  }
</style>

<script>
  const lightbox       = document.getElementById('lightbox');
  const lightboxImg    = document.getElementById('lightbox-img') as HTMLImageElement | null;
  const lightboxTitle  = document.getElementById('lightbox-title');
  const lightboxMeta   = document.getElementById('lightbox-meta');
  const lightboxDims   = document.getElementById('lightbox-dims');
  const closeBtn       = document.getElementById('lightbox-close');
  const backdrop       = document.getElementById('lightbox-backdrop');

  function openLightbox(img: HTMLImageElement) {
    const title  = img.dataset.title      ?? 'Untitled';
    const medium = img.dataset.medium     ?? 'Oil on canvas';
    const year   = img.dataset.year       ?? '';
    const dims   = img.dataset.dimensions ?? '';

    if (lightboxImg) { lightboxImg.src = img.src; lightboxImg.alt = img.alt; }
    if (lightboxTitle) lightboxTitle.textContent = title;
    if (lightboxMeta)  lightboxMeta.textContent  = year ? `${medium} · ${year}` : medium;
    if (lightboxDims)  lightboxDims.textContent  = dims;

    lightbox?.classList.add('open');
    lightbox?.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    lightbox?.classList.remove('open');
    lightbox?.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    setTimeout(() => {
      if (!lightbox?.classList.contains('open') && lightboxImg) {
        lightboxImg.src = '';
      }
    }, 300);
  }

  document.querySelectorAll<HTMLImageElement>('.gallery-img').forEach(img => {
    img.addEventListener('click', () => openLightbox(img));
  });

  closeBtn?.addEventListener('click', closeLightbox);
  backdrop?.addEventListener('click', closeLightbox);
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape' && lightbox?.classList.contains('open')) closeLightbox();
  });
</script>
