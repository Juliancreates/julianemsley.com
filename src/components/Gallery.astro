---
import { Image } from 'astro:assets';
import type { Piece } from '../data/paintings';

interface Props {
  pieces: Piece[];
  section: string;
}

const { pieces, section } = Astro.props;
---

<div class="gallery">
  {pieces.map((piece) => {
    const img = piece.images[0].src;
    const aspect = img.width / img.height;
    return (
    <figure id={piece.slug} style={`--aspect: ${aspect};`}>
      <a href={`/${section}/${piece.slug}`} class="gallery-link">
        <Image
          src={img}
          alt={piece.images[0].alt}
          width={1400}
          quality={88}
          loading="lazy"
          decoding="async"
          class="gallery-img"
        />
      </a>
      <figcaption>
        <p class="fig-title">{piece.title}</p>
        <p class="fig-meta">{piece.medium} · {piece.year}</p>
        <p class="fig-dims">{piece.dimensions}</p>
        {piece.price && <p class="fig-price">{piece.price}</p>}
      </figcaption>
    </figure>
    );
  })}
</div>

<style>
  .gallery {
    display: flex;
    gap: 6rem;
    overflow-x: auto;
    overflow-y: hidden;
    height: 100svh;
    padding: 0.75rem 1rem;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
  }

  .gallery::-webkit-scrollbar {
    display: none;
  }

  figure {
    flex: none;
    /* Width = (gallery height - vertical padding - caption area) × aspect ratio */
    width: calc((100svh - 1.5rem - 4.5rem) * var(--aspect));
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .gallery-link {
    display: block;
    height: calc(100svh - 1.5rem - 4.5rem);
    position: relative;
  }

  .gallery-link::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url('/images/bg-paper.svg');
    background-size: 300px 300px;
    opacity: 0.35;
    pointer-events: none;
    mix-blend-mode: multiply;
  }

  .gallery-link img {
    height: 100%;
    width: auto;
    display: block;
    object-fit: contain;
    opacity: 0;
    transition: opacity 0.35s ease;
  }

  .gallery-img { cursor: pointer; }

  figcaption {
    flex-shrink: 0;
    padding-top: 0.75rem;
    padding-bottom: 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    text-align: right;
  }

  .fig-title {
    font-family: 'Lato', sans-serif;
    font-size: 13px;
    font-weight: 700;
    color: #222;
  }

  .fig-meta {
    font-family: 'Lato', sans-serif;
    font-size: 12px;
    color: #999;
  }

  .fig-dims {
    font-family: 'Lato', sans-serif;
    font-size: 12px;
    color: #bbb;
  }

  .fig-price {
    font-family: 'Lato', sans-serif;
    font-size: 12px;
    font-weight: 700;
    color: #999;
    margin-top: 0.2rem;
  }

  @media (max-width: 750px) {
    .gallery {
      height: 70%;
      min-height: 0;
      padding: 0.75rem 1rem;
      margin: auto 0;
    }
    figure {
      width: calc((70svh - 6rem) * var(--aspect));
    }
    .gallery-link {
      height: calc(70svh - 6rem);
    }
  }

  @media (min-width: 751px) {
    .gallery {
      height: 100vh;
      padding: calc(8rem - 10px) 1rem 5.5rem 2rem;
    }
    figure {
      width: calc((100vh - 15.5rem - 50px) * var(--aspect));
    }
    .gallery-link {
      height: calc(100vh - 15.5rem - 50px);
    }
  }
</style>

<script>
  document.querySelectorAll<HTMLImageElement>('.gallery-img').forEach((img) => {
    if (img.complete) {
      img.style.opacity = '1';
    } else {
      img.addEventListener('load', () => { img.style.opacity = '1'; });
    }
  });

  const hash = window.location.hash.slice(1);
  if (hash) {
    const target = document.getElementById(hash);
    if (target) {
      target.scrollIntoView({ behavior: 'instant', inline: 'start', block: 'nearest' });
    }
  }

  document.querySelectorAll<HTMLAnchorElement>('.gallery-link').forEach((link) => {
    link.addEventListener('click', () => {
      const figure = link.closest('figure');
      if (figure?.id) {
        history.replaceState(null, '', `#${figure.id}`);
      }
    });
  });
</script>
