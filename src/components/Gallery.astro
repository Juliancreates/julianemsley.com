---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface GalleryImage {
  src: ImageMetadata;
  alt: string;
  title?: string;
  medium?: string;
  year?: string;
  dimensions?: string;
}

interface Props {
  images: GalleryImage[];
}

const { images } = Astro.props;
---

<div class="gallery">
  {images.map((image) => (
    <figure>
      <Image
        src={image.src}
        alt={image.alt}
        width={1400}
        quality={88}
        loading="lazy"
        decoding="async"
        class="gallery-img"
        data-title={image.title ?? 'Untitled'}
        data-medium={image.medium ?? 'Oil on canvas'}
        data-year={image.year ?? ''}
        data-dimensions={image.dimensions ?? ''}
      />
    </figure>
  ))}
</div>

<style>
  .gallery {
    display: flex;
    align-items: center;
    gap: 1rem;
    overflow-x: auto;
    overflow-y: hidden;
    height: 100svh;
    padding: 0.75rem 1rem;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
  }

  .gallery::-webkit-scrollbar {
    display: none;
  }

  figure {
    flex-shrink: 0;
    height: 100%;
    display: flex;
    align-items: center;
  }

  figure img {
    height: 100%;
    max-height: 700px;
    width: auto;
    display: block;
    object-fit: contain;
    opacity: 0;
    transition: opacity 0.35s ease;
  }

  .gallery-img { cursor: pointer; }

  @media (max-width: 767px) {
    .gallery {
      height: 100%;
      min-height: 0;
      padding: 0.75rem 1rem;
    }
  }

  @media (min-width: 768px) {
    .gallery {
      height: 100vh;
      padding: 0.75rem 1rem 0.75rem 300px;
      gap: 1rem;
    }
  }
</style>

<script>
  document.querySelectorAll<HTMLImageElement>('.gallery-img').forEach((img) => {
    if (img.complete) {
      img.style.opacity = '1';
    } else {
      img.addEventListener('load', () => { img.style.opacity = '1'; });
    }
  });
</script>
