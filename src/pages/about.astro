---
import Base from '../layouts/Base.astro';
---

<Base title="About | Julian Emsley">
  <div class="about">
    <h1>About</h1>
    <p>Biography and artist statement coming soon.</p>
  </div>
</Base>

<style>
  .about {
    max-width: 600px;
    padding-top: 2rem;
  }

  h1 {
    font-size: 1rem;
    font-weight: 400;
    margin-bottom: 1.5rem;
    color: #666;
  }

  p {
    line-height: 1.6;
    color: #333;
  }
</style>
