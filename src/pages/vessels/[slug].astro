---
import Base from '../../layouts/Base.astro';
import { Image } from 'astro:assets';
import { vessels } from '../../data/vessels';

export function getStaticPaths() {
  return vessels.map(p => ({ params: { slug: p.slug }, props: { piece: p } }));
}

const { piece } = Astro.props;
---

<Base title={`${piece.title} | Julian Emsley`} fullBleed={true} noNav={true} noFooter={true}>
  <div class="detail">
    <div class="detail-images">
      {piece.images.map(img => (
        <Image
          src={img.src}
          alt={img.alt}
          width={1400}
          quality={88}
          loading="eager"
          decoding="async"
          class="detail-img"
        />
      ))}
      {piece.video && (
        <video class="detail-video" src={piece.video} autoplay muted loop playsinline />
      )}
    </div>
    <div class="detail-info">
      <p class="info-title">{piece.title}</p>
      <p class="info-year">{piece.year}</p>
      <p class="info-medium">{piece.medium}</p>
      <p class="info-dims">{piece.dimensions}</p>
      {piece.price && <p class="info-price">{piece.price}</p>}
      {piece.blurb && <p class="info-blurb">{piece.blurb}</p>}
      {piece.caption && <p class="info-caption">{piece.caption}</p>}
      {piece.sold && <p class="info-sold">{piece.sold}</p>}
      {piece.buyLink && <a href={piece.buyLink} class="buy-btn" target="_blank" rel="noopener">BUY</a>}
      <a href={`/vessels#${piece.slug}`} class="back-link">← BACK</a>
    </div>
  </div>
</Base>

<style>
  /* ── Mobile ── */
  @media (max-width: 750px) {
    .detail {
      display: flex;
      flex-direction: column;
      height: 100%;
      overflow: hidden;
    }

    .detail-images {
      flex-shrink: 0;
      display: flex;
      align-items: center;
      gap: 0.5rem;
      overflow-x: auto;
      overflow-y: hidden;
      height: 60%;
      padding: 0.75rem 1rem;
      scrollbar-width: none;
      -webkit-overflow-scrolling: touch;
    }
    .detail-images::-webkit-scrollbar { display: none; }

    .detail-img {
      height: 100%;
      width: auto;
      object-fit: contain;
      flex-shrink: 0;
      display: block;
    }

    .placeholder-img {
      flex-shrink: 0;
      height: 100%;
      aspect-ratio: 3 / 4;
      background: #e8e8e8;
      border-radius: 1px;
    }

    .detail-info {
      flex: 1;
      min-height: 0;
      overflow-y: auto;
      padding: 1.25rem 1rem 2rem;
      display: flex;
      flex-direction: column;
      gap: 0.35rem;
    }
  }

  /* ── Desktop ── */
  @media (min-width: 751px) {
    .detail {
      position: fixed;
      inset: 0;
      display: flex;
      flex-direction: row;
      padding-left: 0;
    }

    .detail-info {
      flex-shrink: 0;
      width: 220px;
      height: 100vh;
      overflow-y: auto;
      padding: max(2rem, calc((100vh - 750px) / 2)) 2rem 2rem;
      text-align: right;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      border-right: 1px solid #f0f0f0;
    }

    .detail-images {
      flex: 1;
      min-width: 0;
      display: flex;
      align-items: center;
      gap: 1.5rem;
      overflow-x: auto;
      overflow-y: hidden;
      height: 100vh;
      padding: 0.75rem 2rem 0.75rem 2.5rem;
      scrollbar-width: none;
      -webkit-overflow-scrolling: touch;
    }
    .detail-images::-webkit-scrollbar { display: none; }

    .detail-img {
      height: 100%;
      max-height: 750px;
      width: auto;
      object-fit: contain;
      flex-shrink: 0;
      display: block;
    }

    .detail-video {
      height: 100%;
      max-height: 750px;
      width: auto;
      flex-shrink: 0;
      display: block;
      object-fit: contain;
    }

    .placeholder-img {
      flex-shrink: 0;
      height: 100%;
      max-height: 750px;
      aspect-ratio: 3 / 4;
      background: #e8e8e8;
      border-radius: 1px;
    }
  }

  /* ── Info typography ── */
  .info-title {
    font-family: 'Lato', sans-serif;
    font-size: 15px;
    color: #222;
  }
  .info-year {
    font-family: 'Lato', sans-serif;
    font-size: 13px;
    color: #555;
  }
  .info-medium {
    font-family: 'Lato', sans-serif;
    font-size: 13px;
    color: #999;
    margin-top: 0.5rem;
  }
  .info-dims {
    font-family: 'Lato', sans-serif;
    font-size: 13px;
    color: #bbb;
  }
  .info-price {
    font-family: 'Lato', sans-serif;
    font-size: 13px;
    font-weight: 700;
    color: #999;
    margin-top: 0.5rem;
  }
  .info-blurb {
    font-family: 'Lato', sans-serif;
    font-size: 13px;
    color: #999;
    line-height: 1.65;
    margin-top: 1.25rem;
  }
  .info-caption {
    font-family: 'Lato', sans-serif;
    font-size: 11px;
    color: #bbb;
    line-height: 1.5;
    margin-top: 1rem;
    font-style: italic;
  }
  .info-sold {
    font-family: 'Lato', sans-serif;
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #bbb;
    margin-top: 1.25rem;
  }
  .buy-btn {
    display: inline-block;
    align-self: flex-end;
    font-family: 'Lato', sans-serif;
    font-size: 13px;
    color: #fff;
    background: #222;
    text-decoration: none;
    padding: 0.35rem 0.75rem;
    margin-top: 1.25rem;
    transition: background 0.2s ease;
  }
  .buy-btn:hover { background: #000; }
  .back-link {
    font-family: 'Lato', sans-serif;
    font-size: 13px;
    font-weight: 700;
    color: #777;
    text-decoration: none;
    margin-top: auto;
    padding-bottom: 2.5rem;
    transition: color 0.2s ease;
  }
  .back-link:hover { color: #222; }
</style>
