  { src: '/images/vessels/vessel 4.jpg', alt: 'Vessel 4', title: 'Wood-fired form',    medium: 'Anagama, natural ash deposit',             year: '2022', dimensions: '40 × 20 cm' },
  { src: '/images/vessels/vessel 5.jpg', alt: 'Vessel 5', title: 'Dense body',         medium: 'Heavily grogged stoneware, reduction',     year: '2023', dimensions: '30 × 15 cm' },
