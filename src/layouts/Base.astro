---
interface Props {
  title?: string;
  fullBleed?: boolean;
}

const { title = 'Julian Emsley', fullBleed = false } = Astro.props;
const currentPath = Astro.url.pathname;

const isActive = (path: string) => {
  if (path === '/') return currentPath === '/' || currentPath === '/paintings';
  return currentPath.startsWith(path);
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Lato:wght@400&display=swap" rel="stylesheet">
    <title>{title}</title>
  </head>
  <body>

    <!-- Mobile: top bar (always transparent, floats over content) -->
    <header class="mobile-header">
      <a href="/" class="logo">
        <img src="/images/signature.png" alt="Julian Emsley" />
      </a>
      <button class="menu-toggle" id="menu-toggle" aria-label="Open menu">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </header>

    <!-- Mobile: full-screen overlay -->
    <div class="mobile-nav" id="mobile-nav">
      <div class="mobile-nav-header">
        <a href="/" class="logo">
          <img src="/images/signature.png" alt="Julian Emsley" />
        </a>
        <button class="menu-close" id="menu-close" aria-label="Close menu">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
            <line x1="1" y1="1" x2="17" y2="17" stroke="#888" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="17" y1="1" x2="1" y2="17" stroke="#888" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </button>
      </div>
      <nav class="overlay-nav">
        <a href="/" class={isActive('/') ? 'active' : ''}>Paintings</a>
        <a href="/vessels" class={isActive('/vessels') ? 'active' : ''}>Vessels</a>
        <a href="/about" class={isActive('/about') ? 'active' : ''}>About</a>
        <a href="mailto:julian@julianemsley.com">Email</a>
        <div class="footer-info">
          <span>julian@julianemsley.com</span>
          <a href="#" class="instagram-link" aria-label="Instagram">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <circle cx="12" cy="12" r="4"/>
              <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="none"/>
            </svg>
          </a>
        </div>
      </nav>
    </div>

    <!-- Desktop: sidebar (fixed, always on top) -->
    <aside class="sidebar">
      <a href="/" class="logo">
        <img src="/images/signature.png" alt="Julian Emsley" />
      </a>
      <nav class="sidebar-nav">
        <a href="/" class={isActive('/') ? 'active' : ''}>Paintings</a>
        <a href="/vessels" class={isActive('/vessels') ? 'active' : ''}>Vessels</a>
        <a href="/about" class={isActive('/about') ? 'active' : ''}>About</a>
        <a href="mailto:julian@julianemsley.com">Email</a>
      </nav>
      <div class="sidebar-footer">
        <span>julian@julianemsley.com</span>
      </div>
    </aside>

    <main class={fullBleed ? 'full-bleed' : ''}>
      <slot />
    </main>

  </body>
</html>

<script>
  const toggle = document.getElementById('menu-toggle');
  const close  = document.getElementById('menu-close');
  const nav    = document.getElementById('mobile-nav');

  toggle?.addEventListener('click', () => {
    nav?.classList.add('open');
    document.body.style.overflow = 'hidden';
  });

  close?.addEventListener('click', () => {
    nav?.classList.remove('open');
    document.body.style.overflow = '';
  });
</script>

<style is:global>
  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: system-ui, sans-serif;
    background: #fff;
    color: #222;
  }

  /* ── Logo ── */
  .logo { display: block; }
  .logo img { height: 86px; width: auto; display: block; }

  /* ── Shared ── */
  .section-label {
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    color: #aaa;
    text-transform: uppercase;
  }

  /* ═══════════════════════════════
     MOBILE
  ═══════════════════════════════ */

  /* Transparent fixed header floats over content */
  .mobile-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.25rem 1.5rem;
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 20;
  }

  .menu-toggle {
    background: none;
    border: none;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    gap: 5px;
    padding: 4px;
  }

  .menu-toggle span {
    display: block;
    width: 22px;
    height: 2px;
    background: #444;
    border-radius: 1px;
  }

  /* Full-screen nav overlay */
  .mobile-nav {
    display: none;
    position: fixed;
    inset: 0;
    background: #fff;
    z-index: 100;
    flex-direction: column;
    padding: 1.25rem 1.5rem 2rem;
  }

  .mobile-nav.open { display: flex; }

  .mobile-nav-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2.5rem;
  }

  .menu-close {
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    line-height: 0;
  }

  .overlay-nav {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .overlay-nav a { text-decoration: none; color: #999999; font-family: 'Lato', sans-serif; font-size: 14px; transition: color 0.2s ease; }
  .overlay-nav a.active { color: #dca26d; }
  .overlay-nav a:hover:not(.active) { color: #000; }

  .footer-info { display: flex; flex-direction: column; gap: 0.75rem; margin-top: 0.5rem; }
  .footer-info span { font-size: 0.8rem; color: #999; }
  .instagram-link { color: #555; }

  /* Desktop sidebar hidden on mobile */
  .sidebar { display: none; }

  /* Mobile main */
  main { padding: 0 1.5rem 4rem; }
  main.full-bleed { padding: 0; }

  /* ═══════════════════════════════
     DESKTOP
  ═══════════════════════════════ */
  @media (min-width: 768px) {
    .mobile-header { display: none; }
    .mobile-nav    { display: none !important; }

    /* Sidebar: fixed, transparent, always on top */
    .sidebar {
      display: flex;
      flex-direction: column;
      gap: 2.5rem;
      position: fixed;
      top: 0; left: 0;
      width: 220px;
      height: 100vh;
      padding: 2.5rem 2rem;
      z-index: 10;
    }

    .sidebar-nav { display: flex; flex-direction: column; gap: 2.5rem; }
    .sidebar-nav a { text-decoration: none; color: #999999; font-family: 'Lato', sans-serif; font-size: 14px; transition: color 0.2s ease; }
    .sidebar-nav a.active { color: #dca26d; }
    .sidebar-nav a:hover:not(.active) { color: #000; }

    .sidebar-footer { margin-top: auto; font-size: 0.75rem; color: #999; }

    /* Regular pages: push content right of sidebar */
    main {
      margin-left: 220px;
      padding: 2.5rem;
      min-height: 100vh;
      overflow-y: auto;
    }

    /* Gallery pages: fill full viewport, sidebar overlays it */
    main.full-bleed {
      margin-left: 0;
      padding: 0;
      position: fixed;
      inset: 0;
      overflow: hidden;
    }
  }
</style>
