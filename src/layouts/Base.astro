---
interface Props {
  title?: string;
  fullBleed?: boolean;
  bodyScroll?: boolean;
}

const { title = 'Julian Emsley', fullBleed = false, bodyScroll = false } = Astro.props;
const currentPath = Astro.url.pathname;

const isActive = (path: string) => {
  if (path === '/') return currentPath === '/' || currentPath === '/paintings';
  return currentPath.startsWith(path);
};
---

<html lang="en" class={bodyScroll ? 'body-scroll' : ''}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Lato:wght@400&display=swap" rel="stylesheet">
    <title>{title}</title>
  </head>
  <body>

    <!-- Mobile: persistent top nav bar -->
    <nav class="mobile-nav-bar">
      <a href="/" class="nav-logo">
        <img src="/images/signature.png" alt="Julian Emsley" />
      </a>
      <div class="nav-main-row">
        <button class="nav-work-btn" id="nav-work-btn" aria-expanded="false">Work</button>
        <a href="/about" class={`nav-link${isActive('/about') ? ' active' : ''}`}>About</a>
        <a href="mailto:julian@julianemsley.com" class="nav-link">Email</a>
      </div>
      <div class="nav-sub-row" id="nav-sub-row" aria-hidden="true">
        <a href="/" class={`sub-link${isActive('/') ? ' active' : ''}`}>Paintings</a>
        <a href="/vessels" class={`sub-link${isActive('/vessels') ? ' active' : ''}`}>Vessels</a>
      </div>
    </nav>

    <!-- Desktop: sidebar (fixed, always on top) -->
    <aside class="sidebar">
      <a href="/" class="logo">
        <img src="/images/signature.png" alt="Julian Emsley" />
      </a>
      <nav class="sidebar-nav">
        <a href="/" class={isActive('/') ? 'active' : ''}>Paintings</a>
        <a href="/vessels" class={isActive('/vessels') ? 'active' : ''}>Vessels</a>
        <a href="/about" class={isActive('/about') ? 'active' : ''}>About</a>
        <a href="mailto:julian@julianemsley.com">Email</a>
      </nav>
      <div class="sidebar-footer">
        <span>julian@julianemsley.com</span>
      </div>
    </aside>

    <main class={fullBleed ? 'full-bleed' : ''}>
      <slot />
    </main>

    <!-- Lightbox (at body level to escape stacking context) -->
    <div class="lightbox" id="lightbox" aria-modal="true" role="dialog" aria-hidden="true">
      <div class="lightbox-backdrop" id="lightbox-backdrop"></div>
      <div class="lightbox-inner">
        <div class="lightbox-image-area" id="lightbox-image-area">
          <img class="lightbox-img" id="lightbox-img" src="" alt="" />
        </div>
        <div class="lightbox-card">
          <button class="lightbox-close" id="lightbox-close" aria-label="Close">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
              <line x1="1" y1="1" x2="13" y2="13" stroke="#bbb" stroke-width="1.5" stroke-linecap="round"/>
              <line x1="13" y1="1" x2="1" y2="13" stroke="#bbb" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </button>
          <p class="lightbox-title" id="lightbox-title"></p>
          <p class="lightbox-meta" id="lightbox-meta"></p>
          <p class="lightbox-dims" id="lightbox-dims"></p>
        </div>
      </div>
    </div>

  </body>
</html>

<script>
  const workBtn = document.getElementById('nav-work-btn');
  const subRow  = document.getElementById('nav-sub-row');

  workBtn?.addEventListener('click', () => {
    const isOpen = subRow?.classList.contains('open');
    if (isOpen) {
      subRow?.classList.remove('open');
      workBtn.classList.remove('active');
      workBtn.setAttribute('aria-expanded', 'false');
      subRow?.setAttribute('aria-hidden', 'true');
    } else {
      subRow?.classList.add('open');
      workBtn.classList.add('active');
      workBtn.setAttribute('aria-expanded', 'true');
      subRow?.setAttribute('aria-hidden', 'false');
    }
  });

  // Lightbox
  const lightbox       = document.getElementById('lightbox');
  const lightboxImg    = document.getElementById('lightbox-img') as HTMLImageElement | null;
  const lightboxTitle  = document.getElementById('lightbox-title');
  const lightboxMeta   = document.getElementById('lightbox-meta');
  const lightboxDims   = document.getElementById('lightbox-dims');
  const closeBtn       = document.getElementById('lightbox-close');
  const backdrop       = document.getElementById('lightbox-backdrop');
  const imageArea      = document.getElementById('lightbox-image-area');

  function openLightbox(img: HTMLImageElement) {
    const title  = img.dataset.title      ?? 'Untitled';
    const medium = img.dataset.medium     ?? 'Oil on canvas';
    const year   = img.dataset.year       ?? '';
    const dims   = img.dataset.dimensions ?? '';

    if (lightboxImg) { lightboxImg.src = img.src; lightboxImg.alt = img.alt; }
    if (lightboxTitle) lightboxTitle.textContent = title;
    if (lightboxMeta)  lightboxMeta.textContent  = year ? `${medium} · ${year}` : medium;
    if (lightboxDims)  lightboxDims.textContent  = dims;

    lightbox?.classList.add('open');
    lightbox?.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    lightbox?.classList.remove('open');
    lightbox?.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    setTimeout(() => {
      if (!lightbox?.classList.contains('open') && lightboxImg) {
        lightboxImg.src = '';
      }
    }, 300);
  }

  document.querySelectorAll<HTMLImageElement>('.gallery-img').forEach(img => {
    img.addEventListener('click', () => openLightbox(img));
  });

  closeBtn?.addEventListener('click', closeLightbox);
  backdrop?.addEventListener('click', closeLightbox);
  imageArea?.addEventListener('click', (e) => {
    if (e.target === imageArea) closeLightbox();
  });
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape' && lightbox?.classList.contains('open')) closeLightbox();
  });
</script>

<style is:global>
  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: system-ui, sans-serif;
    background: #fff;
    color: #222;
  }

  /* ── Logo ── */
  .logo { display: block; }
  .logo img { height: 86px; width: auto; display: block; }

  /* ── Shared ── */
  .section-label {
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    color: #aaa;
    text-transform: uppercase;
  }

  /* ═══════════════════════════════
     MOBILE
  ═══════════════════════════════ */

  @media (max-width: 767px) {
    /* Lock viewport — no page scroll */
    html, body { height: 100svh; overflow: hidden; }
    body { display: flex; flex-direction: column; }

    /* Nav bar: always visible, sits above content in flex stack */
    .mobile-nav-bar {
      flex-shrink: 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.75rem;
      background: #fff;
      padding: 1.25rem 1.25rem 0;
      z-index: 20;
    }

    .nav-logo img {
      height: 52px;
      width: auto;
      display: block;
    }

    .nav-main-row {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 2rem;
    }

    .nav-work-btn {
      background: none;
      border: none;
      padding: 0;
      cursor: pointer;
      font-family: 'Lato', sans-serif;
      font-size: 14px;
      color: #999;
      transition: color 0.2s ease;
    }
    .nav-work-btn:hover, .nav-work-btn.active { color: #dca26d; }

    .nav-link {
      font-family: 'Lato', sans-serif;
      font-size: 14px;
      color: #999;
      text-decoration: none;
      transition: color 0.2s ease;
    }
    .nav-link:hover { color: #000; }
    .nav-link.active { color: #dca26d; }

    /* Sub-row: slides in below main nav row */
    .nav-sub-row {
      display: flex;
      justify-content: center;
      gap: 2rem;
      overflow: hidden;
      max-height: 0;
      transition: max-height 0.3s ease, padding 0.3s ease;
    }
    .nav-sub-row.open {
      max-height: 3rem;
      padding: 0.5rem 0 0.75rem;
    }

    .sub-link {
      font-family: 'Lato', sans-serif;
      font-size: 14px;
      color: #999;
      text-decoration: none;
      transition: color 0.2s ease;
    }
    .sub-link:hover { color: #000; }
    .sub-link.active { color: #dca26d; }

    /* Main: flex child fills remaining viewport height */
    main {
      flex: 1;
      min-height: 0;
      overflow: hidden;
      padding: 0;
    }
    main:not(.full-bleed) {
      padding: 1.5rem;
      overflow-y: auto;
    }
    main.full-bleed {
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    /* Desktop sidebar hidden on mobile */
    .sidebar { display: none; }
  }

  /* About page (and any bodyScroll page): allow normal document scroll so Safari hides its UI on scroll */
  @media (max-width: 767px) {
    html.body-scroll,
    html.body-scroll body {
      height: auto;
      overflow: visible;
    }
    html.body-scroll .mobile-nav-bar {
      position: sticky;
      top: 0;
    }
    html.body-scroll main,
    html.body-scroll main:not(.full-bleed) {
      flex: none;
      overflow: visible;
      padding: 0;
    }
  }

  /* Hide mobile elements at desktop widths */
  @media (min-width: 768px) {
    .mobile-nav-bar { display: none; }
  }

  /* ═══════════════════════════════
     DESKTOP
  ═══════════════════════════════ */
  @media (min-width: 768px) {
    /* Sidebar: fixed, transparent, always on top */
    .sidebar {
      display: flex;
      flex-direction: column;
      gap: 2.5rem;
      position: fixed;
      top: 0; left: 0;
      width: 220px;
      height: 100vh;
      padding: 2.5rem 2rem;
      z-index: 10;
    }

    .sidebar-nav { display: flex; flex-direction: column; gap: 2.5rem; }
    .sidebar-nav a { text-decoration: none; color: #999999; font-family: 'Lato', sans-serif; font-size: 14px; transition: color 0.2s ease; }
    .sidebar-nav a.active { color: #dca26d; }
    .sidebar-nav a:hover:not(.active) { color: #000; }

    .sidebar-footer { margin-top: auto; font-size: 0.75rem; color: #999; }

    /* Regular pages: push content right of sidebar */
    main {
      margin-left: 220px;
      padding: 2.5rem;
      min-height: 100vh;
      overflow-y: auto;
    }

    /* Gallery pages: fill full viewport */
    main.full-bleed {
      margin-left: 0;
      padding: 0;
      position: fixed;
      inset: 0;
      overflow: hidden;
    }
  }

  /* ═══════════════════════════════
     LIGHTBOX
  ═══════════════════════════════ */
  .lightbox {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 200;
    flex-direction: column;
  }
  .lightbox.open { display: flex; }

  .lightbox-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.85);
  }

  .lightbox-close {
    position: absolute;
    top: 1.25rem;
    right: 1.75rem;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    line-height: 0;
  }

  .lightbox-inner {
    position: relative;
    z-index: 205;
    display: flex;
    flex-direction: column;
    width: 100%;
    height: 100%;
  }

  .lightbox-image-area {
    flex: 1;
    min-height: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 3.5rem 1.5rem 1rem;
    overflow: hidden;
    opacity: 0;
    transition: opacity 0.25s ease;
  }
  .lightbox.open .lightbox-image-area { opacity: 1; }

  .lightbox-img {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    display: block;
  }

  .lightbox-card {
    position: relative;
    flex-shrink: 0;
    background: #fff;
    padding: 1.25rem 1.75rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.25s ease 0.08s, transform 0.25s ease 0.08s;
  }
  .lightbox.open .lightbox-card {
    opacity: 1;
    transform: translateY(0);
  }

  .lightbox-title {
    font-family: 'Lato', sans-serif;
    font-size: 15px;
    color: #222;
  }
  .lightbox-meta {
    font-family: 'Lato', sans-serif;
    font-size: 13px;
    color: #999;
  }
  .lightbox-dims {
    font-family: 'Lato', sans-serif;
    font-size: 13px;
    color: #bbb;
  }
</style>
