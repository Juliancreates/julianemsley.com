---
interface Props {
  title?: string;
  fullBleed?: boolean;
  bodyScroll?: boolean;
  noNav?: boolean;
  noLogo?: boolean;
  noFooter?: boolean;
}

const { title = 'Julian Emsley', fullBleed = false, bodyScroll = false, noNav = false, noLogo = false, noFooter = false } = Astro.props;
const currentPath = Astro.url.pathname;

const isActive = (path: string) => {
  if (path === '/') return currentPath === '/' || currentPath.startsWith('/paintings');
  return currentPath.startsWith(path);
};
---

<html lang="en" class={bodyScroll ? 'body-scroll' : ''}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Lato:wght@400;700&family=Josefin+Sans:wght@300;400&display=swap" rel="stylesheet">
    <title>{title}</title>
  </head>
  <body>

    {!noNav && (
      <>
        <!-- Centered logo -->
        {!noLogo && (
          <a href="/" class="logo">
            <img src="/images/signature.png" alt="Julian Emsley" />
          </a>
        )}

        <!-- Name top-right -->
        {!noLogo && (
          <a href="https://instagram.com/julianemsley" target="_blank" rel="noopener" class="site-name">Julian Emsley</a>
        )}

        <!-- Top nav links -->
        <nav class="top-nav">
          <a href="/" class={isActive('/') ? 'active' : ''}>Paintings</a>
          <a href="/vessels" class={isActive('/vessels') ? 'active' : ''}>Vessels</a>
          <a href="/about" class={isActive('/about') ? 'active' : ''}>About</a>
        </nav>

      </>
    )}

    <!-- Bottom bar -->
    {!noFooter && (
      <div class="bottom-bar">
        <a href="mailto:julian@julianemsley.com" class="bottom-link">julian@julianemsley.com</a>
        <a href="https://instagram.com/julianemsley" target="_blank" rel="noopener" class="bottom-link">@julianemsley</a>
      </div>
    )}

    <main class={`${fullBleed ? 'full-bleed' : ''}${noNav ? ' no-nav' : ''}`}>
      <slot />
    </main>

    <slot name="overlay" />

  </body>
</html>


<style is:global>
  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: system-ui, sans-serif;
    background: #fbf7f2 url('/images/bg-paper.svg') repeat;
    background-size: 1200px 900px;
    color: #222;
  }

  /* ── Logo ── */
  .logo {
    position: fixed;
    top: 1rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 20;
  }
  .logo img { height: 60px; width: auto; display: block; opacity: 0.7; }

  /* ── Site name ── */
  /* ── Site name ── */
  .site-name {
    position: fixed;
    top: calc(1rem + 30px);
    right: 1.75rem;
    transform: translateY(-50%);
    font-family: 'Lato', sans-serif;
    font-size: 12px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #999;
    text-decoration: none;
    transition: color 0.2s ease;
    z-index: 20;
  }
  .site-name:hover { color: #333; }

/* ── Top nav ── */
  .top-nav {
    position: fixed;
    top: calc(1rem + 30px);
    left: 1.75rem;
    transform: translateY(-50%);
    display: flex;
    gap: 2rem;
    z-index: 20;
  }
  .top-nav a {
    font-family: 'Lato', sans-serif;
    font-size: 12px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    text-decoration: none;
    color: #999;
    transition: color 0.2s ease;
  }
  .top-nav a.active { color: #dca26d; }
  .top-nav a:hover:not(.active) { color: #333; }

  /* ── Bottom bar ── */
  .bottom-bar {
    position: fixed;
    bottom: 1.25rem;
    left: 1.75rem;
    right: 1.75rem;
    display: flex;
    justify-content: space-between;
    z-index: 20;
  }
  .bottom-link {
    font-family: 'Lato', sans-serif;
    font-size: 11px;
    letter-spacing: 0.1em;
    color: #bbb;
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .bottom-link:hover { color: #555; }

  /* ── Shared ── */
  .section-label {
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    color: #aaa;
    text-transform: uppercase;
  }

  /* ═══════════════════════════════
     MOBILE
  ═══════════════════════════════ */
  @media (max-width: 750px) {
    html, body { height: 100svh; overflow: hidden; }
    body { display: flex; flex-direction: column; }

    main {
      flex: 1;
      min-height: 0;
      overflow: hidden;
      padding: 0;
    }
    main:not(.full-bleed) {
      padding: 1.5rem;
      overflow-y: auto;
    }
    main.full-bleed {
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }
  }

  /* About page: allow normal document scroll */
  @media (max-width: 750px) {
    html.body-scroll,
    html.body-scroll body {
      height: auto;
      overflow: visible;
    }
    html.body-scroll main,
    html.body-scroll main:not(.full-bleed) {
      flex: none;
      overflow: visible;
      padding: 0;
    }
  }

  /* ═══════════════════════════════
     DESKTOP
  ═══════════════════════════════ */
  @media (min-width: 751px) {
    main {
      padding: 2.5rem;
      min-height: 100vh;
      overflow-y: auto;
    }
    main.full-bleed {
      padding: 0;
      position: fixed;
      inset: 0;
      overflow: hidden;
    }
    main.no-nav {
      padding: 0;
    }
  }

</style>
